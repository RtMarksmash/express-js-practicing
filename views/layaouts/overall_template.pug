doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        link(rel="stylesheet", href="/main.css")
        block styles 
        title #{pageTitle}
    body 
        header.main-header 
            nav.main-header__nav
                ul.main-header__item-list
                    li.main-header__item
                        a.active(href="/" , class=(path ==="/" ? 'activate' : '' )) shop 
                    li.main-header__item 
                        a(href="/admin/add-products" , class=(path === "/admin/add-products" ? 'activate': '')) add product 
        block content 